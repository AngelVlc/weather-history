{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@weather-history/shared-dynamodb-client": ["__mocks__/@weather-history/shared-dynamodb-client.ts"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "__mocks__/**/*"],
  "exclude": ["node_modules", "dist"]
}
