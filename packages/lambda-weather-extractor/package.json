{
  "name": "@weather-history/lambda-weather-extractor",
  "version": "1.0.0",
  "description": "Lambda function to extract weather data from AVAMET",
  "main": "dist/handler.js",
  "scripts": {
    "build": "esbuild src/handler.ts --bundle --platform=node --outfile=dist/handler.js --external:aws-sdk --external:jest",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "invoke": "sam local invoke WeatherExtractorFunction -e events/lambda-input.json"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@weather-history/shared-dynamodb-client": "*",
    "@weather-history/shared-types": "*",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}
