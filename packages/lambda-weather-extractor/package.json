{
  "name": "@weather-history/lambda-weather-extractor",
  "version": "1.0.0",
  "description": "Lambda function to extract weather data from AVAMET",
  "main": "dist/handler.js",
  "scripts": {
    "build": "tsc && npm run copy-deps",
    "copy-deps": "cp -r ../../node_modules ./dist/",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "invoke": "sam local invoke WeatherExtractorFunction -e events/lambda-input.json"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}
