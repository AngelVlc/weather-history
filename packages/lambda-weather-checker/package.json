{
  "name": "@weather-history/lambda-weather-checker",
  "version": "1.0.0",
  "description": "Lambda function to check weather data completeness and send notifications",
  "main": "dist/handler.js",
  "scripts": {
    "build": "esbuild src/handler.ts --bundle --platform=node --outfile=dist/handler.js --external:aws-sdk --external:jest",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "invoke": "sam local invoke WeatherCheckerFunction -e events/checker.json"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-ses": "^3.0.0",
    "@weather-history/shared-dynamodb-client": "*",
    "@weather-history/shared-types": "*"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}