{
  "name": "@weather-history/lambda-weather-api",
  "version": "1.0.0",
  "description": "Lambda function to serve weather data via API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "start": "sam local start-api --docker-network weather-history_weather-history-network --port 3001 -n events/env.json",
    "invoke": "DYNAMODB_ENDPOINT=http://localhost:8000 DYNAMODB_TABLE_NAME=weather-data AWS_ACCESS_KEY_ID=fake AWS_SECRET_ACCESS_KEY=fake node -e \"const{handler}=require('./dist/index');handler(require('./events/stations-event.json')).then(r=>console.log(r.body))\""
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/credential-providers": "^3.1032.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}
